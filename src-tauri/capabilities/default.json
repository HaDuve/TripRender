{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "allow-save-video-to-photos-library",
    "fs:default",
    "fs:allow-appcache-write",
    "fs:allow-cache-write-recursive",
    "dialog:default",
    "fs:allow-write-file",
    "os:default"
  ]
}