# Copy to .env (never commit .env)

# Web build / Mapbox
MAPBOX_TOKEN=pk.your.mapbox.token

# App Store Connect API key (upload via scripts/ios-submit.js — not for local `tauri ios build` signing)
# https://v2.tauri.app/distribute/app-store/#authentication
#
# altool (`scripts/ios-submit.js`): use APPLE_API_KEY_ID **or** APPLE_API_KEY (same value: Key ID).
APPLE_API_KEY_ID=
# Tauri name for the same Key ID (optional if APPLE_API_KEY_ID is set — pipeline bridges it)
# APPLE_API_KEY=

APPLE_API_ISSUER=

# Required only if you use `tauri ios build --ci` (headless / some CI). Local `build:submit:ios` does not use --ci.
# Path to AuthKey_<KEY_ID>.p8 — default ~/private_keys/AuthKey_<KEY_ID>.p8 is auto-detected when Key ID is set.
# https://v2.tauri.app/distribute/sign/ios/
# APPLE_API_KEY_PATH=

# `npm run build:submit:ios` runs `build:web` first, then passes `tauri ios build --build-number <n>` (CFBundleVersion).
# Gitignored `.ios-build-number` stores the last successful upload; it is updated only
# after altool succeeds. Seed if you already shipped builds: echo 42 > .ios-build-number
# https://v2.tauri.app/distribute/app-store/
